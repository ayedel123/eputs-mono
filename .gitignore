# .gitignore для Yarn Workspaces

# Node modules
**/node_modules/
node_modules/

# Build outputs
**/dist/
**/build/
**/out/
**/.next/
**/coverage/

# TypeScript build info
**/*.tsbuildinfo

# Module Federation generated types
**/@mf-types/
**/dist-types/

# Logs
**/logs/
**/*.log
yarn-error.log

# IDE
.vscode/
.idea/

# Environment
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
.cache/
.parcel-cache/

# Yarn
.yarn/cache/
.yarn/unplugged/
.pnp.*
.yarn-integrity

# Keep workspace root clean
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions